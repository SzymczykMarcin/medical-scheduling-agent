# Cloud Run runtime profile
RUNTIME_PROFILE=cloud-run

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=https://your-frontend.example.com
DEMO_MODE=false

# Speech-to-text
# The Cloud Run demo script deploys the backend with NVIDIA L4 for ASR.
ASR_PROVIDER=faster-whisper
ASR_MODEL_NAME=large-v3-turbo
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=int8_float16

# Bielik through local Ollama inside the GPU backend container
LLM_PROVIDER=ollama-http
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0
OLLAMA_LLM_LIBRARY=cuda
OLLAMA_KEEP_ALIVE=-1
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_AUTH_MODE=none
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1

# Vector RAG
# Cloud Run uses local EmbeddingGemma inside the GPU backend container plus BigQuery Vector Search.
RAG_BACKEND=bigquery-vector
RAG_INDEX_MODE=managed-vector
BIGQUERY_PROJECT_ID=your-project-id
BIGQUERY_DATASET_ID=rag_dataset
BIGQUERY_TABLE_ID=medical_scheduling_rules
EMBEDDING_PROVIDER=ollama-http
EMBEDDING_BASE_URL=http://127.0.0.1:11434
EMBEDDING_MODEL_NAME=embeddinggemma:latest
EMBEDDING_AUTH_MODE=none
EMBEDDING_DEVICE=cpu
RAG_DOCUMENT_DIR=/app/data/rag
RAG_SOURCE_URI=
RAG_MAX_CONTEXT_CHARACTERS=8000
RETRIEVAL_LIMIT=4
RAG_CHUNK_CHARACTERS=1200
RAG_CHUNK_OVERLAP=180

# Demo storage
# CLOUD_STORAGE_MODE=ephemeral is honest demo mode: SQLite lives in /tmp.
# For durable appointments, set:
#   CLOUD_STORAGE_MODE=persistent
#   CALENDAR_STORAGE_BACKEND=sql
#   DATABASE_URL=postgresql+psycopg://...
CALENDAR_STORAGE_BACKEND=sqlite
SEED_DEMO_CALENDAR=true
CLOUD_STORAGE_MODE=ephemeral
DATABASE_URL=
SQLITE_DATABASE_URL=sqlite:////tmp/medical-scheduling-agent/demo.sqlite3
