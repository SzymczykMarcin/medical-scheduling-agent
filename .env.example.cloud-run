# Cloud Run runtime profile
RUNTIME_PROFILE=cloud-run

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=https://your-frontend.example.com
DEMO_MODE=false

# Speech-to-text
# For a public demo, run ASR in the backend container only if the image includes the model runtime.
ASR_PROVIDER=faster-whisper
ASR_MODEL_NAME=large-v3-turbo
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=int8_float16

# Bielik through a Cloud Run / Ollama-compatible model service
LLM_PROVIDER=ollama-http
OLLAMA_BASE_URL=https://your-bielik-service-url
OLLAMA_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0
OLLAMA_TIMEOUT_SECONDS=120
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1

# Vector RAG
# This profile uses Chroma for a simple cloud demo. Rebuild the index after deployment.
RAG_BACKEND=chroma
EMBEDDING_MODEL_NAME=sdadas/mmlw-retrieval-roberta-large
CHROMA_PERSIST_DIR=/tmp/medical-scheduling-agent/chroma
CHROMA_COLLECTION_NAME=medical_scheduling_rules
RAG_DOCUMENT_DIR=/app/data/rag
RAG_MAX_CONTEXT_CHARACTERS=8000
RETRIEVAL_LIMIT=4
RAG_CHUNK_CHARACTERS=1200
RAG_CHUNK_OVERLAP=180

# Demo storage
SQLITE_DATABASE_URL=sqlite:////tmp/medical-scheduling-agent/demo.sqlite3
