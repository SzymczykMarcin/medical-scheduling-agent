# Cloud Run runtime profile
RUNTIME_PROFILE=cloud-run

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080
CORS_ORIGINS=https://your-frontend.example.com
DEMO_MODE=false

# Speech-to-text
# CPU mode is slower, but keeps the public backend demo deployable without a second GPU service.
ASR_PROVIDER=faster-whisper
ASR_MODEL_NAME=large-v3-turbo
ASR_DEVICE=cpu
ASR_COMPUTE_TYPE=int8

# Bielik through a Cloud Run / Ollama-compatible model service
LLM_PROVIDER=ollama-http
OLLAMA_BASE_URL=https://your-bielik-service-url
OLLAMA_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_AUTH_MODE=google-id-token
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1

# Vector RAG
# This profile uses Chroma for a simple cloud demo. Rebuild the index after deployment.
RAG_BACKEND=chroma
EMBEDDING_MODEL_NAME=sdadas/mmlw-retrieval-roberta-large
CHROMA_PERSIST_DIR=/tmp/medical-scheduling-agent/chroma
CHROMA_COLLECTION_NAME=medical_scheduling_rules
RAG_DOCUMENT_DIR=/app/data/rag
RAG_SOURCE_URI=
RAG_INDEX_MODE=local-chroma
RAG_MAX_CONTEXT_CHARACTERS=8000
RETRIEVAL_LIMIT=4
RAG_CHUNK_CHARACTERS=1200
RAG_CHUNK_OVERLAP=180

# Demo storage
# CLOUD_STORAGE_MODE=ephemeral is honest demo mode: Chroma and SQLite live in /tmp.
# For durable appointments, set:
#   CLOUD_STORAGE_MODE=persistent
#   CALENDAR_STORAGE_BACKEND=sql
#   DATABASE_URL=postgresql+psycopg://...
# For managed vector RAG, set:
#   RAG_BACKEND=bigquery-vector
#   RAG_INDEX_MODE=managed-vector
#   BIGQUERY_PROJECT_ID=your-project-id
CALENDAR_STORAGE_BACKEND=sqlite
SEED_DEMO_CALENDAR=true
CLOUD_STORAGE_MODE=ephemeral
DATABASE_URL=
SQLITE_DATABASE_URL=sqlite:////tmp/medical-scheduling-agent/demo.sqlite3
