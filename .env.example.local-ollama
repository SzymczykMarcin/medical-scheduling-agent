# Local Ollama runtime profile
RUNTIME_PROFILE=local-ollama

# Backend
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8097
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5397,http://127.0.0.1:5397
DEMO_MODE=false

# Speech-to-text
ASR_PROVIDER=faster-whisper
ASR_MODEL_NAME=large-v3-turbo
ASR_DEVICE=cuda
ASR_COMPUTE_TYPE=int8_float16

# Bielik through a local Ollama-compatible model server
LLM_PROVIDER=ollama-http
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=SpeakLeash/bielik-4.5b-v3.0-instruct:Q8_0
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_AUTH_MODE=none
LLM_MAX_NEW_TOKENS=512
LLM_TEMPERATURE=0.1

# Vector RAG
EMBEDDING_MODEL_NAME=sdadas/mmlw-retrieval-roberta-large
EMBEDDING_DEVICE=cpu
RAG_BACKEND=chroma
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION_NAME=medical_scheduling_rules
RAG_DOCUMENT_DIR=data/rag
RAG_SOURCE_URI=
RAG_INDEX_MODE=local-chroma
RAG_MAX_CONTEXT_CHARACTERS=8000
RETRIEVAL_LIMIT=4
RAG_CHUNK_CHARACTERS=1200
RAG_CHUNK_OVERLAP=180

# Demo storage
CALENDAR_STORAGE_BACKEND=sqlite
SEED_DEMO_CALENDAR=true
CLOUD_STORAGE_MODE=ephemeral
SQLITE_DATABASE_URL=sqlite:///data/demo.sqlite3
